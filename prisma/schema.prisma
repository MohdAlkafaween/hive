generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  password      String
  name          String           @default("")
  phone         String           @default("")
  role          String           @default("STAFF") // Roles: ADMIN, MANAGER, STAFF, BARISTA
  permissions   String           @default("[]") // JSON array of allowed pages for MANAGER role
  isActive      Boolean          @default(true)
  createdById   Int?
  createdBy     User?            @relation("CreatedByAdmin", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers  User[]           @relation("CreatedByAdmin")
  createdAt     DateTime         @default(now())
  auditLogs            StaffAuditLog[]
  cashRegisters        CashRegister[]
  expenses             CafeExpense[]
  processedLogs        Log[]          @relation("LogProcessedBy")
  createdSubscriptions Subscription[] @relation("SubscriptionCreatedBy")
}

model StaffAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  role      String
  event     String
  ip        String   @default("unknown")
  details   String?
  createdAt DateTime @default(now())
}

model Student {
  id               Int            @id @default(autoincrement())
  studentNumber    Int?           @unique // human-readable sequential ID (STD-0001)
  fullName         String
  phone            String         @unique
  email            String?
  major            String?
  dateOfBirth      DateTime?
  gender           String?        // "male", "female", or null
  emergencyContact String?
  emergencyPhone   String?
  university       String?
  status           String         @default("ACTIVE") // ACTIVE, SUSPENDED, BANNED, GRADUATED
  referralSource   String?
  rfidUuid         String?        @unique
  photoUrl         String?
  qrToken          String?        @unique
  createdAt        DateTime       @default(now())
  lifetimeCheckIns Int            @default(0)
  // Customer auth fields
  password         String?        // bcrypt hash. null = staff-registered, hasn't set up login yet
  isLoginEnabled   Boolean        @default(false) // admin can disable customer login
  lastLoginAt      DateTime?      // track last customer login
  subscriptions    Subscription[]
  logs             Log[]
  transactions     Transaction[]
  promoUsages      PromoUsage[]
  notes            StudentNote[]
  waitlistEntries  WaitlistEntry[]
  baristaOrders    BaristaOrder[]
  feedbacks        ItemFeedback[]
}

model Subscription {
  id                 Int       @id @default(autoincrement())
  studentId          Int?
  student            Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentName        String    @default("")
  planType           String
  startDate          DateTime  @default(now())
  expiryDate         DateTime
  totalVisitsAllowed Int
  visitsUsed         Int       @default(0)
  isActive           Boolean   @default(true)
  isFrozen           Boolean   @default(false)
  frozenAt           DateTime?
  freezeDays         Int       @default(0)
  windowStart        DateTime? // Start of current 24h check-in window; set on entry deduction, cleared on window expiry
  createdBy          Int?      // staff user ID who sold this subscription
  createdByUser      User?     @relation("SubscriptionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  planId             Int?
  plan               SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())
  transactions       Transaction[]

  @@index([studentId, isActive])
  @@index([expiryDate])
  @@index([windowStart])
}

model Log {
  id           Int       @id @default(autoincrement())
  studentId    Int?
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentName  String    @default("")
  checkInTime  DateTime  @default(now())
  checkOutTime DateTime?
  date         String
  method          String?   @default("MANUAL") // RFID, QR, MANUAL, SEARCH, AUTO_CHECKOUT
  processedBy     Int?      // staff user ID, null for kiosk self-check-ins
  processedByUser User?     @relation("LogProcessedBy", fields: [processedBy], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([studentId, date])
}

// NOTE: amountPaid/discountAmount use Float because SQLite stores all numbers as REAL.
// True Decimal is not available in SQLite. Application-layer rounding (Math.round(x*100)/100)
// is applied in subscription and transaction creation routes to prevent accumulation errors.
// TODO: In a future migration to PostgreSQL, convert these to Decimal for exact currency math.
model Transaction {
  id             Int       @id @default(autoincrement())
  studentId      Int?
  student        Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  studentName    String    @default("")
  amountPaid     Float
  planType       String
  gateway        String
  discountAmount Float     @default(0)
  receiptNumber  String?   // e.g., "RCP-00012" — shared with barista orders for unified receipts
  type           String    @default("SALE") // SALE, REFUND, VOID
  voidedAt       DateTime?
  voidedBy       Int?      // staff user ID who voided
  voidReason     String?
  refundOf       Int?      // links to original transaction ID for refunds
  createdAt      DateTime  @default(now())

  @@index([createdAt])
}

// ─── CAFÉ / BARISTA ───

model MenuCategory {
  id        Int        @id @default(autoincrement())
  name      String
  nameAr    String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now())
  items     MenuItem[]
}

model MenuItem {
  id           Int                @id @default(autoincrement())
  name         String
  nameAr       String?
  price        Float
  costPrice    Float              @default(0) // cost to the business
  imageUrl     String?
  isOutOfStock Boolean            @default(false)
  isDeleted    Boolean            @default(false) // soft-delete: hides from menu but preserves order history
  isCustom     Boolean            @default(false) // true for ad-hoc custom items created during orders
  categoryId   Int?
  category     MenuCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  orders       BaristaOrder[]
  options      MenuItemOption[]
  feedbacks    ItemFeedback[]
}

model MenuItemOption {
  id         Int                   @id @default(autoincrement())
  menuItemId Int
  menuItem   MenuItem              @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name       String                // e.g., "Size", "Topping"
  nameAr     String?
  type       String                @default("ADD_TO_PRICE") // ADD_TO_PRICE or SET_PRICE
  required   Boolean               @default(false)
  sortOrder  Int                   @default(0)
  values     MenuItemOptionValue[]
}

model MenuItemOptionValue {
  id        Int            @id @default(autoincrement())
  optionId  Int
  option    MenuItemOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  label     String         // e.g., "Small", "Large"
  labelAr   String?
  price     Float          // price to add or set
  costPrice Float          @default(0)
  isDefault Boolean        @default(false)
  sortOrder Int            @default(0)
}

model BaristaOrder {
  id              Int           @id @default(autoincrement())
  menuItemId      Int?
  menuItem        MenuItem?     @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  studentId       Int?
  student         Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  registerId      Int?          // Links to the CashRegister used at time of sale
  register        CashRegister? @relation(fields: [registerId], references: [id], onDelete: SetNull)
  quantity        Int           @default(1)
  totalPrice      Float
  costPrice       Float         @default(0) // snapshot cost at time of sale
  finalPrice      Float         @default(0) // actual charged price after options
  selectedOptions String        @default("[]") // JSON of selected options
  paymentMethod   String        @default("CASH") // CASH, CARD, OTHER
  receiptNumber   String?       // e.g., "RCP-00001"
  // Order status for customer ordering flow
  status          String        @default("COMPLETED") // PENDING, ACCEPTED, PREPARING, READY, COMPLETED, CANCELLED
  customerNote    String?       // "no ice", "extra shot", etc.
  orderedBy       String        @default("STAFF") // STAFF or CUSTOMER
  orderGroupId    String?       // UUID grouping items from one customer cart
  createdAt       DateTime      @default(now())
  feedbacks       ItemFeedback[]

  @@index([createdAt])
  @@index([orderGroupId])
  @@index([status])
}

// ─── EXPENSES ───

model CafeExpense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  date        DateTime @default(now())
  category    String?  // Ingredients, Supplies, Utilities, etc.
  addedBy     Int
  user        User     @relation(fields: [addedBy], references: [id])
  addedByName String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

// ─── CASH REGISTER ───

model CashRegister {
  id              Int       @id @default(autoincrement())
  shiftId         Int?
  shift           StaffShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  userName        String    @default("")
  date            DateTime  @default(now())
  openingCash     Float
  closingCash     Float?
  expectedCash    Float?
  cashSales       Float     @default(0)
  cardSales       Float     @default(0)
  cashDiscrepancy Float?
  notes           String?
  status          String    @default("OPEN") // OPEN or CLOSED
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())
  baristaOrders   BaristaOrder[]
}

// ─── PROMOS ───

model PromoCode {
  id              Int          @id @default(autoincrement())
  code            String       @unique
  discountType    String       @default("AMOUNT")
  discountAmount  Float
  bonusEntries    Int          @default(0)
  isActive        Boolean      @default(true)
  maxUses         Int          @default(0)
  timesUsed       Int          @default(0)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  usages          PromoUsage[]
}

model PromoUsage {
  id          Int       @id @default(autoincrement())
  promoCodeId Int
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  studentId   Int?
  student     Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentName String    @default("")
  discount    Float
  createdAt   DateTime  @default(now())
}

model StudentNote {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content   String
  authorId  Int?
  authorName String  @default("")
  createdAt DateTime @default(now())
}

model StaffShift {
  id            Int            @id @default(autoincrement())
  userId        Int
  email         String
  role          String
  clockIn       DateTime       @default(now())
  clockOut      DateTime?
  date          String
  cashRegisters CashRegister[]
}

model AppSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model WaitlistEntry {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      String
  position  Int
  status    String   @default("WAITING")
  createdAt DateTime @default(now())
}

// ─── BACKUP ───

model BackupLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  fileName  String
  fileSize  Int
  success   Boolean
  error     String?
  trigger   String   @default("MANUAL") // MANUAL, SCHEDULED, STARTUP
}

// ─── SUBSCRIPTION PLANS ───

// ─── FEEDBACK ───

model ItemFeedback {
  id            Int           @id @default(autoincrement())
  baristaOrderId Int?
  baristaOrder  BaristaOrder? @relation(fields: [baristaOrderId], references: [id], onDelete: SetNull)
  menuItemId    Int?
  menuItem      MenuItem?     @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  studentId     Int?
  student       Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  rating        Int           // 1-5 stars
  comment       String?
  createdAt     DateTime      @default(now())

  @@index([menuItemId])
  @@index([studentId])
}

model SubscriptionPlan {
  id            Int            @id @default(autoincrement())
  name          String
  nameAr        String?
  durationDays  Int
  totalVisits   Int            // -1 for unlimited
  price         Float
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}
