# ─── HIVE Environment Variables ───

# REQUIRED — Generate with: openssl rand -base64 32
# Must be set before running the app. Never commit the real value.
JWT_SECRET=

# Database path (SQLite)
DATABASE_URL="file:./dev.db"

# Seed credentials (only used for initial admin creation via /api/auth/seed)
SEED_ADMIN_EMAIL=admin@hive.study
SEED_ADMIN_PASSWORD=

# Set to 'true' to enable the /api/auth/seed endpoint. Disable after initial setup.
ALLOW_SEED=false

# Set to 'true' when behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY=false

# Backup directory (absolute path, outside the repo)
BACKUP_DIR=

# Timezone: Must match the business location for correct date calculations.
TZ=Asia/Amman

# Development only — comma-separated list of allowed dev origins
# DEV_ORIGINS=192.168.1.100,192.168.1.101

# Set to 'true' when running production build over HTTP LAN (npm start on local network)
# Remove or set to 'false' for real HTTPS deployments
ALLOW_HTTP=false

# NODE_ENV is set automatically by Next.js. Override only if needed.
# NODE_ENV=development
